# Last.fm API credentials — get from https://www.last.fm/api/account/create
LASTFM_API_KEY=your_api_key
LASTFM_API_SECRET=your_api_secret
# Session key — generated by: python setup.py --lastfm (no password needed)
LASTFM_SESSION_KEY=your_session_key

# How often to poll YT Music history (in seconds)
POLL_INTERVAL=300

# How many recent YT Music history items to fetch each poll
HISTORY_LIMIT=50
